generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppPlatform {
  ios
  android
  harmonyos
}

enum CatalogNodeType {
  category
  chapter
  section
  paper
}

enum QuestionType {
  single_choice
  multiple_choice
  true_false
  fill_blank
  short_answer
  material
}

enum MaterialAccessType {
  free
  vip
}

enum StudyMode {
  practice
  exam
}

enum FeedbackStatus {
  open
  processing
  resolved
  rejected
}

enum AiProviderStatus {
  enabled
  disabled
}

model App {
  id          String      @id @default(cuid())
  appKey      String      @unique
  name        String
  platform    AppPlatform
  packageName String?
  bankId      String
  bank        QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  config      Json?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  visits      AppDailyMetric[]
  sales       SalesDailyMetric[]
}

model QuestionBank {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  version       String?
  sourceRoot    String?
  sourceManifest String?
  questionCount Int           @default(0)
  subjects      Subject[]
  apps          App[]
  materials     MaterialResource[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Subject {
  id        String       @id @default(cuid())
  bankId    String
  bank      QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int          @default(0)
  isDefault Boolean      @default(false)
  catalogs  CatalogNode[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([bankId, sortOrder])
  @@unique([bankId, name])
}

model CatalogNode {
  id            String          @id @default(cuid())
  subjectId     String
  subject       Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parentId      String?
  parent        CatalogNode?    @relation("CatalogTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      CatalogNode[]   @relation("CatalogTree")
  type          CatalogNodeType
  name          String
  level         Int             @default(2)
  sourceSectionId String?
  sourcePath    String?
  sourceFile    String?
  questionCount Int             @default(0)
  sortOrder     Int             @default(0)
  questions     Question[]
  progress      UserProgress[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([subjectId, parentId, sortOrder])
  @@index([sourceSectionId])
}

model Question {
  id          String       @id
  catalogId   String
  catalog     CatalogNode  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  type        QuestionType
  legacyType  String?
  choiceMode  String?
  stem        Json
  options     Json?
  answer      Json
  analysis    Json?
  scoringRubric Json?
  sourceRef   Json?
  rawPayload   Json?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  favorites   UserFavorite[]
  wrongItems  UserWrongQuestion[]
  answers     UserAnswer[]

  @@index([catalogId, sortOrder])
  @@index([type])
}

model User {
  id        String   @id @default(cuid())
  phone     String?  @unique
  nickname  String?
  isDev      Boolean  @default(false)
  defaultSubjectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress  UserProgress[]
  favorites UserFavorite[]
  wrongQuestions UserWrongQuestion[]
  answers   UserAnswer[]
  practiceRecords PracticeRecord[]
  examRecords ExamRecord[]
  feedbacks UserFeedback[]
}

model PracticeRecord {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appKey    String
  questionId String
  questionTitle String?
  mode      String?
  correct   Boolean?
  payload   Json
  createdAt DateTime @default(now())

  @@index([userId, appKey, createdAt])
}

model ExamRecord {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appKey    String
  title     String?
  mode      String?
  score     Float?
  accuracy  Float?
  submitted Boolean  @default(true)
  payload   Json
  createdAt DateTime @default(now())

  @@index([userId, appKey, createdAt])
}

model MaterialResource {
  id          String             @id @default(cuid())
  bankId      String
  bank        QuestionBank        @relation(fields: [bankId], references: [id], onDelete: Cascade)
  title       String
  subjectName String?
  description String?
  accessType  MaterialAccessType  @default(free)
  coverUrl    String?
  fileUrl     String?
  fileType    String?
  previewMeta Json?
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([bankId, accessType, sortOrder])
}

model UserProgress {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogId   String
  catalog     CatalogNode @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  mode        StudyMode
  done        Int         @default(0)
  correct     Int         @default(0)
  wrong       Int         @default(0)
  minutes     Int         @default(0)
  lastStudiedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, catalogId, mode])
  @@index([userId, mode])
}

model UserFavorite {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@unique([userId, questionId])
  @@index([userId, createdAt])
}

model UserWrongQuestion {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  wrongCount  Int         @default(1)
  active      Boolean     @default(true)
  lastWrongAt DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, questionId])
  @@index([userId, active, lastWrongAt])
}

model UserAnswer {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  mode        StudyMode
  answer      Json
  isCorrect   Boolean?
  score       Float?
  payload     Json?
  createdAt   DateTime    @default(now())

  @@index([userId, mode, createdAt])
  @@index([questionId])
}

model UserFeedback {
  id          String         @id @default(cuid())
  userId      String?
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  appKey      String?
  questionId  String?
  type        String
  content     String
  contact     String?
  status      FeedbackStatus @default(open)
  payload     Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([questionId])
}

model AiModelConfig {
  id          String           @id @default(cuid())
  name        String
  provider    String
  model       String
  endpoint    String?
  apiKeyAlias String?
  status      AiProviderStatus @default(disabled)
  config      Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, provider])
}

model AppDailyMetric {
  id          String   @id @default(cuid())
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  day         DateTime
  visits      Int      @default(0)
  activeUsers Int      @default(0)
  practiceCount Int    @default(0)
  examCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([appId, day])
  @@index([day])
}

model SalesDailyMetric {
  id          String   @id @default(cuid())
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  day         DateTime
  orders      Int      @default(0)
  amountFen   Int      @default(0)
  refunds     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([appId, day])
  @@index([day])
}
